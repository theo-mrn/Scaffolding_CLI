name: CD

on:
  push:
    branches: [main]
    tags: ["v*"]

jobs:
{% if cd_job_build %}
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Docker metadata
        id: meta
        uses: docker/metadata-action@v5
        with:
          images: {% raw %}${{ secrets.DOCKER_USERNAME }}{% endraw %}/{{ project_name }}
          tags: |
            type=sha,format=short
            type=semver,pattern={% raw %}{{version}}{% endraw %}
            type=raw,value=latest,enable={% raw %}{{is_default_branch}}{% endraw %}

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Build image
        uses: docker/build-push-action@v5
        with:
          push: false
          tags: {% raw %}${{ steps.meta.outputs.tags }}{% endraw %}
          labels: {% raw %}${{ steps.meta.outputs.labels }}{% endraw %}
{% if cd_job_push %}
          outputs: type=docker,dest=/tmp/image.tar

      - name: Upload image artifact
        uses: actions/upload-artifact@v4
        with:
          name: docker-image
          path: /tmp/image.tar
{% endif %}
{% endif %}
{% if cd_job_push %}
  push:
{% if cd_job_build %}
    needs: build
{% endif %}
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Docker metadata
        id: meta
        uses: docker/metadata-action@v5
        with:
          images: {% raw %}${{ secrets.DOCKER_USERNAME }}{% endraw %}/{{ project_name }}
          tags: |
            type=sha,format=short
            type=semver,pattern={% raw %}{{version}}{% endraw %}
            type=raw,value=latest,enable={% raw %}{{is_default_branch}}{% endraw %}
{% if cd_job_build %}

      - name: Download image artifact
        uses: actions/download-artifact@v4
        with:
          name: docker-image
          path: /tmp

      - name: Load image
        run: docker load --input /tmp/image.tar
{% endif %}

      - name: Log in to Docker Hub
        uses: docker/login-action@v3
        with:
          username: {% raw %}${{ secrets.DOCKER_USERNAME }}{% endraw %}
          password: {% raw %}${{ secrets.DOCKER_PASSWORD }}{% endraw %}

      - name: Push image
        uses: docker/build-push-action@v5
        with:
          push: true
          tags: {% raw %}${{ steps.meta.outputs.tags }}{% endraw %}
          labels: {% raw %}${{ steps.meta.outputs.labels }}{% endraw %}
{% if cd_job_trivy %}

      - name: Trivy image scan
        uses: aquasecurity/trivy-action@master
        with:
          image-ref: {% raw %}${{ fromJSON(steps.meta.outputs.json).tags[0] }}{% endraw %}
          format: table
          exit-code: "1"
          severity: CRITICAL,HIGH
          {%- if project_type in ("node", "react") %}
          skip-dirs: /usr/local/lib/node_modules/npm
          {%- endif %}
{% endif %}
{% if cd_job_sbom %}

      - name: Generate SBOM
        uses: aquasecurity/trivy-action@master
        with:
          image-ref: {% raw %}${{ fromJSON(steps.meta.outputs.json).tags[0] }}{% endraw %}
          format: cyclonedx
          output: sbom.json

      - name: Upload SBOM
        uses: actions/upload-artifact@v4
        with:
          name: sbom
          path: sbom.json
{% endif %}
{% endif %}
